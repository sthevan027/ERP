# Arquivo de seed (NÃO use no frontend)
# 1) Copie para: web/.env.seed
# 2) Preencha com dados do seu projeto Supabase

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Opcional (customização do seed)
SEED_ORG_NAME=Galpão Demo
SEED_WAREHOUSE_NAME=Galpão Principal
SEED_METRIC_UNIT=pallet
SEED_METRIC_LABEL=Pallets
SEED_CAPACITY_TOTAL=1000
SEED_CLIENT_NAME=Cliente Demo

# Contas criadas (você pode trocar)
SEED_MANAGER_EMAIL=gestor@demo.local
SEED_MANAGER_PASSWORD=ChangeMe123!
SEED_ANALYST_EMAIL=analista@demo.local
SEED_ANALYST_PASSWORD=ChangeMe123!
SEED_CLIENT_EMAIL=cliente@demo.local
SEED_CLIENT_PASSWORD=ChangeMe123!


